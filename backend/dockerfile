# syntax=docker/dockerfile:1
ARG PYTHON_VERSION=3.11.3
FROM python:${PYTHON_VERSION}-slim as base

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# אבטחה: יצירת משתמש לא-ניהולי
ARG UID=10001
RUN adduser --disabled-password --gecos "" --home "/nonexistent" --shell "/sbin/nologin" --no-create-home --uid "${UID}" appuser

# בגלל שה-Context הוא השורש, אנחנו צריכים להצביע לנתיב המלא של הדרישות
RUN --mount=type=cache,target=/root/.cache/pip \
    --mount=type=bind,source=backend/requirements.txt,target=requirements.txt \
    python -m pip install -r requirements.txt

# העתקת תיקיית ה-backend לתוך /app בקונטיינר
COPY --chown=appuser:appuser backend/ .

# העתקת תיקיית ה-config (כדי שהבאקנד יוכל לקרוא את ה-YAMLים)
COPY --chown=appuser:appuser config/ /app/config/

USER appuser
EXPOSE 8000

# הרצה - וודא ש-app/main.py קיים בתוך תיקיית backend
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]