# =========================
# FastAPI backend settings
# =========================
APP_NAME=Daily Status Manager API
ENVIRONMENT=development

# Storage mode:
# - local: only local Excel files
# - s3: only S3 Excel files
# - local_and_s3 (or dual/hybrid): local + S3 mirror
STORAGE_MODE=local

# Local storage path (used in local and local_and_s3 modes)
LOCAL_STORAGE_DIR=./local_storage

# Seed file for first-time master people creation
SEED_PEOPLE_FILE=./backend/data/sample_people.csv

# CORS for React dev server
CORS_ORIGINS=http://localhost:5173

# =========================
# AWS S3 settings (required when STORAGE_MODE=s3 or local_and_s3)
# =========================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
S3_BUCKET_NAME=your_bucket_name
S3_SNAPSHOTS_PREFIX=snapshots
S3_MASTER_KEY=master/people_master.xlsx
S3_LOCATIONS_KEY=master/locations.xlsx

# =========================
# React frontend settings
# =========================
VITE_API_BASE_URL=http://localhost:8000
